{
    "name": "vendor/neotel-websocket",
    "description": "Neotel websocket client + Laravel integration",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "textalk/websocket": "^1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\NeotelWebsocket\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\NeotelWebsocket\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Josh Rudesill",
            "email": "joshrudesill@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
