NEOTEL_ENABLED=false
NEOTEL_WEBSOCKET_URL=wss://ix3.neotel2000.com:10000/agent
NEOTEL_USER=
NEOTEL_PASSWORD=

NEOTEL_VERIFY_SSL=true
NEOTEL_READ_TIMEOUT=30
NEOTEL_INITIAL_BACKOFF_SECONDS=1
NEOTEL_MAX_BACKOFF_SECONDS=30
NEOTEL_EVENTS=true
NEOTEL_DB=true

# Optional: set a dedicated log channel in the host Laravel app.
# Example: neotel
NEOTEL_LOG_CHANNEL=

# Optional: override package user-agent string sent in websocket headers.
NEOTEL_USER_AGENT=vendor-neotel-websocket/0.1
